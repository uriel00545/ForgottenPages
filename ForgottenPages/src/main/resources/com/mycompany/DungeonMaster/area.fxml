<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600"
            prefWidth="800"
            style="-fx-background-color: #1a1a2e;"
            xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.DungeonMaster.controller.AreaController">

    <!-- Topo: barra de navegação de sub-telas -->
    <top>
        <HBox alignment="CENTER"
              spacing="10"
              style="-fx-background-color: #16213e; -fx-padding: 10;">

            <Button onAction="#tfogueira"
                    text="FOGUEIRA"
                    textAlignment="CENTER"
                    style="-fx-background-color: #3a1a0a;
                           -fx-text-fill: #FFAA44;
                           -fx-border-color: #FF6600;
                           -fx-border-width:1;
                           -fx-border-radius:4;
                           -fx-background-radius:4;">

                <font>
                    <Font name="System Bold Italic" size="12.0"/>
                </font>

            </Button>

            <Button onAction="#tinv"
                    text="INVENTÁRIO"
                    style="-fx-background-color: #1a2a1a;
                           -fx-text-fill: #88CC88;
                           -fx-border-color: #448844;
                           -fx-border-width:1;
                           -fx-border-radius:4;
                           -fx-background-radius:4;"/>

            <Button onAction="#tLoja"
                    text="LOJA"
                    prefHeight="27.0"
                    prefWidth="78.0"
                    style="-fx-background-color: #2a2a0a;
                           -fx-text-fill: #CCCC44;
                           -fx-border-color: #888800;
                           -fx-border-width:1;
                           -fx-border-radius:4;
                           -fx-background-radius:4;"/>

        </HBox>
    </top>

    <!-- Centro: painel de sub-cena (fogueira/inv/loja) -->
    <center>
        <AnchorPane fx:id="AreaCena"
                    style="-fx-background-color: #12122a;"/>
    </center>

    <!-- Rodapé: botão para batalha -->
    <bottom>
        <HBox alignment="CENTER"
              spacing="20"
              style="-fx-background-color: #0f0f1e;
                     -fx-padding: 12;
                     -fx-border-color: #333366;
                     -fx-border-width: 2 0 0 0;">

            <Label fx:id="lblWaveInfo"
                   text="Próxima: Wave 1"
                   style="-fx-text-fill: #AAAAAA;
                          -fx-font-size:13;"/>

            <Button onAction="#irParaBatalha"
                    text="ENTRAR EM BATALHA"
                    prefHeight="44"
                    prefWidth="220"
                    style="-fx-background-color: #8B0000;
                           -fx-text-fill: white;
                           -fx-font-size: 15;
                           -fx-font-weight: bold;
                           -fx-border-color: #FFD700;
                           -fx-border-width:2;
                           -fx-border-radius:6;
                           -fx-background-radius:6;"/>

        </HBox>
    </bottom>

</BorderPane>