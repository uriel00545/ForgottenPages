<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ForgottenPages.controller.MenuController"
      alignment="CENTER" spacing="18" prefWidth="640" prefHeight="480"
      style="-fx-background-color: #0d0d1a;">
    <padding><Insets top="40" bottom="40" left="80" right="80"/></padding>

    <Label text="FORGOTTEN  PAGES"
           style="-fx-text-fill: #FFD700; -fx-font-size: 36; -fx-font-weight: bold;
                  -fx-effect: dropshadow(gaussian, #FF6600, 12, 0.4, 0, 0);"/>
    <Label text="Inspirado em Library pf Ruina"
           style="-fx-text-fill: #888888; -fx-font-size: 13; -fx-font-style: italic;"/>

    <Region prefHeight="10"/>

    <HBox alignment="CENTER" spacing="10">
        <Label text="Nome:" style="-fx-text-fill: #CCCCCC; -fx-font-size: 14;"/>
        <TextField fx:id="tfNome" promptText="Seu nome de Sinner..." prefWidth="220"
                   style="-fx-background-color: #1a1a3a; -fx-text-fill: white;
                          -fx-border-color: #FFD700; -fx-border-width: 1;
                          -fx-border-radius: 4; -fx-background-radius: 4; -fx-font-size: 14;"/>
    </HBox>

    <Button text="⚔  JOGAR" onAction="#jogar" prefWidth="260" prefHeight="42"
            style="-fx-background-color: #8B0000; -fx-text-fill: white; -fx-font-size: 16;
                   -fx-font-weight: bold; -fx-border-color: #FFD700; -fx-border-width: 2;
                   -fx-border-radius: 6; -fx-background-radius: 6;
                   -fx-effect: dropshadow(gaussian, #FF0000, 8, 0.3, 0, 0);"/>

    <Button text="🏆  RANKING" onAction="#abrirRanking" prefWidth="260" prefHeight="36"
            style="-fx-background-color: #1a2a1a; -fx-text-fill: #88CC88; -fx-font-size: 14;
                   -fx-border-color: #448844; -fx-border-width: 1;
                   -fx-border-radius: 5; -fx-background-radius: 5;"/>

    <Button text="📜  CRÉDITOS" onAction="#abrirCreditos" prefWidth="260" prefHeight="36"
            style="-fx-background-color: #1a1a3a; -fx-text-fill: #8888CC; -fx-font-size: 14;
                   -fx-border-color: #444488; -fx-border-width: 1;
                   -fx-border-radius: 5; -fx-background-radius: 5;"/>

    <Button text="✖  ENCERRAR" onAction="#fecharJogo" prefWidth="260" prefHeight="36"
            style="-fx-background-color: #2a0a0a; -fx-text-fill: #CC4444; -fx-font-size: 14;
                   -fx-border-color: #882222; -fx-border-width: 1;
                   -fx-border-radius: 5; -fx-background-radius: 5;"/>
</VBox>
